{
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/dist/client/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "functions": {
        "api/index.js": {
            "includeFiles": "dist/**"
        }
    }
}